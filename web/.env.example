# Copy to .env.local and fill in values.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Google OAuth (optional — if unset, demo login is enabled)
# Get these at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (AI tutor)
ANTHROPIC_API_KEY=

# Devin API (for DevinTask activities — optional in v1, capstones are stubbed)
DEVIN_API_KEY=
DEVIN_TASKS_ENABLED=false

# Backend API
SOF_API_URL=http://localhost:8000
